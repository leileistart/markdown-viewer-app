{
  "name": "markdown-viewer-app",
  "private": true,
  "version": "1.0.0",
  "description": "轻量、美观、智能的 Markdown 文件浏览器",
  "author": "leileistart",
  "license": "MIT",
  "main": "electron.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "vite build && electron-builder --win portable",
    "tauri": "tauri"
  },
  "build": {
    "appId": "com.markdown.viewer",
    "productName": "Markdown阅览室",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "src-tauri/icons/icon.ico"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.4",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@types/markdown-it": "^14.1.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
