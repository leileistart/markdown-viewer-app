{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-ask",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:read-all",
    "fs:read-dirs",
    "fs:read-files",
    "fs:allow-exists",
    "fs:allow-read-file"
  ]
}
